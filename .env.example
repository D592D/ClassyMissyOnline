# Classy Missy Collection — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.

# ── 1. WordPress Headless CMS ──────────────────────────────────
NEXT_PUBLIC_WP_GRAPHQL_URL=https://your-wordpress.com/graphql
BACKEND_WP_URL=https://your-wordpress.com

# ── 2. Site Config ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://classymissy.gy

# ── 3. WhatsApp Contact ────────────────────────────────────────
# Guyanese number format: country code + 7-digit local number
NEXT_PUBLIC_WHATSAPP_NUMBER=5926965612
NEXT_PUBLIC_WHATSAPP_LABEL=+592 696 5612

# ── 4. MMG Payment Gateway ─────────────────────────────────────
MMG_MERCHANT_ID=your_merchant_id_here
MMG_CLIENT_ID=your_client_id_here
MMG_GATEWAY_URL=https://business.mymmg.gy/payment/checkout

# MMG_PUBLIC_KEY is the PUBLIC key issued TO YOU by MMG.
# You use it to ENCRYPT outbound payloads → MMG decrypts with their private key.
# Format: paste the full PEM with \n for line breaks, wrapped in quotes.
# Example:
#   MMG_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEF...\n-----END PUBLIC KEY-----"
#
# ⚠️  NEVER store a private key in this file or in Vercel env vars.
# ⚠️  NEVER commit a real key to source control.
MMG_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n(your MMG-issued public key here)\n-----END PUBLIC KEY-----"
